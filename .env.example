# Local-dev environment for the agent backends + main-app shell.
# Copy to `.env` and fill in the values you have. Phase 6 retired the
# Postgres / Django / HelioGram stack — Supabase is the new control
# plane. See ``.env.prod.example`` for the full production reference.

# ---------------------------------------------------------------------------
# Frontend (main-app shell — the Phase 5.8 stripped questionnaire app).
# ---------------------------------------------------------------------------
VITE_COMMUNITY_URL=

# ---------------------------------------------------------------------------
# Shared agent backend secrets (consumed by every FastAPI agent service).
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=
REPLICATE_API_TOKEN=
REPLICATE_IMAGE_MODEL=bytedance/seedream-4.5
REPLICATE_VIDEO_MODEL=kwaivgi/kling-v2.5-turbo-pro
IMAGE_PROMPT_LLM_MODEL=openai/gpt-4o
VIDEO_PROMPT_LLM_MODEL=openai/gpt-4o
STORYTELLER_LLM_MODEL=openai/gpt-4o
STORYTELLER_FALLBACK_MODELS=
CAMPAIGN_MAKER_LLM_MODEL=openai/gpt-4o
CAMPAIGN_MAKER_FALLBACK_MODELS=
SOUL_PRINT_LLM_MODEL=openai/gpt-4o
SOUL_PRINT_FALLBACK_MODELS=

# ---------------------------------------------------------------------------
# External /v1/* surface (X-API-Key path). Leaving these blank in dev runs
# the agents in legacy mode (env-var validation, no Supabase call).
# ---------------------------------------------------------------------------
HELIO_EXTERNAL_API_KEYS_IMAGE=
HELIO_EXTERNAL_API_KEYS_VIDEO=
HELIO_EXTERNAL_API_KEYS_STORYTELLER=
HELIO_EXTERNAL_API_KEYS_CAMPAIGN=
HELIO_EXTERNAL_API_KEYS_SOUL_PRINT=

# ---------------------------------------------------------------------------
# Supabase (optional in dev — without it the agents stay in legacy mode).
# Once these are set, agents resolve tenants via JWT/X-API-Key against
# Supabase and write audit rows to ``agent_runs``.
# ---------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWKS_URL=
