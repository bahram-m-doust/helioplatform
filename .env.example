# ---------------------------------------------------------------------------
# Frontend (main-app) — read by Vite at build time.
# ---------------------------------------------------------------------------
VITE_OPENROUTER_API_KEY=
VITE_OPENROUTER_MODEL=openai/gpt-4o
VITE_OPENROUTER_FALLBACK_MODELS=
VITE_COMMUNITY_URL=http://localhost:5050

# Heliogram (social platform) API base. Leave empty to auto-use
# `http://<current-hostname>:8010` (LAN-friendly during dev).
VITE_HELIOGRAM_API_BASE_URL=

# AI agent microservices. Leave empty to auto-use the ports below.
# image-generator -> 8020, video-generator -> 8030,
# storyteller -> 8040, campaign-maker -> 8050.
VITE_IMAGE_AGENT_API_BASE_URL=
VITE_VIDEO_AGENT_API_BASE_URL=
VITE_STORYTELLER_AGENT_API_BASE_URL=
VITE_CAMPAIGN_MAKER_AGENT_API_BASE_URL=

# Optional per-endpoint overrides (only set if you proxy behind a gateway).
VITE_IMAGE_PROMPT_API_URL=
VITE_IMAGE_GENERATION_API_URL=
VITE_VIDEO_IMAGE_PROMPT_API_URL=
VITE_VIDEO_PROMPT_FROM_IMAGE_API_URL=
VITE_VIDEO_GENERATION_API_URL=
VITE_STORYTELLER_CHAT_API_URL=
VITE_CAMPAIGN_MAKER_CHAT_API_URL=

# ---------------------------------------------------------------------------
# Shared agent backend secrets (consumed by the FastAPI agent services).
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=
REPLICATE_API_TOKEN=
REPLICATE_IMAGE_MODEL=bytedance/seedream-4.5
REPLICATE_VIDEO_MODEL=kwaivgi/kling-v2.5-turbo-pro
IMAGE_PROMPT_LLM_MODEL=openai/gpt-4o
VIDEO_PROMPT_LLM_MODEL=openai/gpt-4o
STORYTELLER_LLM_MODEL=openai/gpt-4o
STORYTELLER_FALLBACK_MODELS=
CAMPAIGN_MAKER_LLM_MODEL=openai/gpt-4o
CAMPAIGN_MAKER_FALLBACK_MODELS=

# Framer-compatible image API security. In production the token is required.
FRAMER_IMAGE_API_TOKEN=
FRAMER_IMAGE_ALLOWED_ORIGINS=https://octara.framer.website
FRAMER_IMAGE_RATE_LIMIT_PER_MINUTE=6
FRAMER_IMAGE_MAX_PROMPT_CHARS=1500
FRAMER_IMAGE_MAX_REFERENCE_IMAGES=0
AGENT_CORS_ALLOWED_ORIGINS=http://localhost:4000,http://localhost:5173,http://localhost:5174,https://octara.framer.website

# ---------------------------------------------------------------------------
# Dev bootstrapping for HelioGram community app (npm run dev).
# ---------------------------------------------------------------------------
COMMUNITY_RUN_MODE=native
COMMUNITY_BACKEND_PORT=8010
COMMUNITY_FRONTEND_PORT=5050
COMMUNITY_AUTO_MIGRATE=true

# ---------------------------------------------------------------------------
# Production security (HelioGram Django backend).
# In production set DEBUG=False, supply a strong SECRET_KEY and list every
# public hostname/IP in ALLOWED_HOSTS (comma-separated).
# ---------------------------------------------------------------------------
DEBUG=False
SECRET_KEY=
ALLOWED_HOSTS=103.174.102.124

# Restrict the backend port to loopback only so direct public access to
# :8010 is blocked; all external traffic must flow through nginx.
# Set to 0.0.0.0 only for LAN dev if you know what you are doing.
HELIO_BACKEND_BIND=127.0.0.1
