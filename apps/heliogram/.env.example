# ========================================
# HelioGram Environment Variables
# Copy to .env in project root
# ========================================

# --- App Core ---
# PRODUCTION: DEBUG must be False. SECRET_KEY must be a long random string
# (Django will refuse to boot with the insecure default when DEBUG=False).
# ALLOWED_HOSTS must contain every public hostname/IP that serves the app.
DEBUG=False
SECRET_KEY=
ALLOWED_HOSTS=103.174.102.124
FRONTEND_URL=http://localhost:5050
CORS_ALLOWED_ORIGINS=http://localhost:5050,http://localhost:4000,http://127.0.0.1:4000
HELIO_FRONTEND_PORT=5050
HELIO_BACKEND_PORT=8010
# Host interface the backend port binds to. 127.0.0.1 keeps :8010 off the
# public internet so all traffic must reach it through nginx. Use 0.0.0.0
# only for trusted LAN dev.
HELIO_BACKEND_BIND=127.0.0.1
ALLOW_LAN_DEV_ORIGINS=True
APP_NAME="HelioGram"
DEFAULT_LOCALE=en

# --- Database ---
# Local dev quick start
USE_SQLITE=True

# Docker/production database (used when USE_SQLITE=False)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=heliogram
DB_USER=heliogram
DB_PASSWORD=heliogram
DB_HOST=db
DB_PORT=5432
DB_CONN_MAX_AGE=60

# --- JWT ---
JWT_ACCESS_TOKEN_LIFETIME=30
JWT_REFRESH_TOKEN_LIFETIME=10080

# --- Storage ---
# When backend runs from apps/heliogram/backend, use local ./storage
STORAGE_ROOT=./storage
MAX_UPLOAD_SIZE=52428800
REPLICATE_API_TOKEN=
REPLICATE_IMAGE_MODEL=bytedance/seedream-4.5
REPLICATE_VIDEO_MODEL=kwaivgi/kling-v2.5-turbo-pro
IMAGE_PROMPT_LLM_MODEL=openai/gpt-4o
VIDEO_PROMPT_LLM_MODEL=openai/gpt-4o

# --- Optional Email ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=



