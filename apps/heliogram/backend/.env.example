# ========================================
# HelioGram Backend Environment Variables
# Copy to backend/.env when running Django directly
# ========================================

SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_URL=http://localhost:5050
ALLOW_LAN_DEV_ORIGINS=True
APP_NAME="HelioGram"
DEFAULT_LOCALE=en

# Local dev default
USE_SQLITE=True

# Production/Docker database settings (USE_SQLITE=False)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=heliogram
DB_USER=heliogram
DB_PASSWORD=heliogram
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=60

JWT_ACCESS_TOKEN_LIFETIME=30
JWT_REFRESH_TOKEN_LIFETIME=10080

STORAGE_ROOT=./storage
MAX_UPLOAD_SIZE=52428800

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=



