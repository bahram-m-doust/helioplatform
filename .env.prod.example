# ============================================================================
# helio-platform — PRODUCTION environment template.
#
# 1. Copy this file to `.env.prod` on the server.
# 2. Fill in every value marked REQUIRED.
# 3. Deploy:
#      docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
#
# The dev stack (docker-compose.yml + .env) is unaffected by this file.
# ============================================================================

# ---------------------------------------------------------------------------
# Public address. The canonical URL is the domain served over HTTPS via
# Let's Encrypt (see DEPLOY.md §6b.3 Path B for the bootstrap). The bare IP
# is kept in the allow / CORS / CSRF lists further down so we can still
# reach the backend during DNS outages.
# ---------------------------------------------------------------------------
PUBLIC_URL=https://platform.helio.ae
PUBLIC_HTTP_PORT=80
PUBLIC_HTTPS_PORT=443

# ---------------------------------------------------------------------------
# Django / HelioGram backend (REQUIRED in production).
# ---------------------------------------------------------------------------
# Generate once with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
# List every hostname the backend may be reached at (comma-separated). The
# bare IP is kept so we can hit the server during DNS outages or before a
# certificate is provisioned.
ALLOWED_HOSTS=103.174.102.124,platform.helio.ae,localhost
# Browser origins allowed to call the API. List both http and https for the
# domain so the switch to TLS doesn't need a redeploy.
CORS_ALLOWED_ORIGINS=http://103.174.102.124,http://platform.helio.ae,https://platform.helio.ae
FRONTEND_URL=https://platform.helio.ae/heliogram
APP_NAME=HelioGram
DEFAULT_LOCALE=en

# CSRF: comma-separated list of full origins (scheme + host[:port]) that are
# allowed to POST to Django (notably the admin login form). If left unset,
# Django auto-derives a sane default from CORS_ALLOWED_ORIGINS + ALLOWED_HOSTS.
CSRF_TRUSTED_ORIGINS=http://103.174.102.124,http://platform.helio.ae,https://platform.helio.ae

# Cookie security flags. TRUE is correct once HTTPS is in front (the
# default for this stack — see DEPLOY.md §6b.3 Path B). Flip both to
# False *temporarily* if you need to debug over plain HTTP on the bare IP.
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Seed superuser. The entrypoint only creates the user if it does not exist
# yet, so changing the password here after first boot has no effect (manage
# passwords via `python manage.py changepassword` inside the container).
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=

# JWT lifetimes (minutes).
JWT_ACCESS_TOKEN_LIFETIME=30
JWT_REFRESH_TOKEN_LIFETIME=10080

# Uploads.
MAX_UPLOAD_SIZE=52428800

# Email (optional; default is console backend which just logs to stdout).
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ---------------------------------------------------------------------------
# Postgres (USE_SQLITE is hard-coded to False in docker-compose.prod.yml).
# ---------------------------------------------------------------------------
DB_NAME=heliogram
DB_USER=heliogram
DB_PASSWORD=change-me-strong-password
DB_CONN_MAX_AGE=60

# ---------------------------------------------------------------------------
# Agent backends (FastAPI microservices behind /api/image, /api/video, ...).
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=
REPLICATE_API_TOKEN=
REPLICATE_IMAGE_MODEL=bytedance/seedream-4.5
REPLICATE_VIDEO_MODEL=kwaivgi/kling-v2.5-turbo-pro
IMAGE_PROMPT_LLM_MODEL=openai/gpt-4o
VIDEO_PROMPT_LLM_MODEL=openai/gpt-4o
STORYTELLER_LLM_MODEL=openai/gpt-4o
STORYTELLER_FALLBACK_MODELS=
CAMPAIGN_MAKER_LLM_MODEL=openai/gpt-4o
CAMPAIGN_MAKER_FALLBACK_MODELS=

# ---------------------------------------------------------------------------
# Frontend (main-app) — baked into the static bundle at build time.
#
# Keep these as **relative / same-origin** paths (the defaults below) so the
# bundle works whether it's reached via the bare IP, the custom domain, or
# HTTPS once TLS is provisioned. nginx already routes each prefix to the
# correct upstream. Override only if you host an agent on a different origin.
# ---------------------------------------------------------------------------
VITE_HELIOGRAM_API_BASE_URL=/
VITE_IMAGE_AGENT_API_BASE_URL=/api/image
VITE_VIDEO_AGENT_API_BASE_URL=/api/video
VITE_STORYTELLER_AGENT_API_BASE_URL=/api/storyteller
VITE_CAMPAIGN_MAKER_AGENT_API_BASE_URL=/api/campaign
VITE_COMMUNITY_URL=/heliogram
VITE_OPENROUTER_API_KEY=
VITE_OPENROUTER_MODEL=openai/gpt-4o
VITE_OPENROUTER_FALLBACK_MODELS=
