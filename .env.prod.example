# ============================================================================
# helio-platform — PRODUCTION environment template.
#
# 1. Copy this file to `.env.prod` on the server.
# 2. Fill in every value marked REQUIRED.
# 3. Deploy:
#      docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
#
# The dev stack (docker-compose.yml + .env) is unaffected by this file.
# ============================================================================

# ---------------------------------------------------------------------------
# Public address. The canonical URL is the domain served over HTTPS via
# Let's Encrypt (see DEPLOY.md §6b.3 Path B for the bootstrap). The bare IP
# is kept in the allow / CORS / CSRF lists further down so we can still
# reach the backend during DNS outages.
# ---------------------------------------------------------------------------
PUBLIC_URL=https://api.helio.ae
PUBLIC_HTTP_PORT=80
PUBLIC_HTTPS_PORT=443

# ---------------------------------------------------------------------------
# Django / HelioGram backend (REQUIRED in production).
# ---------------------------------------------------------------------------
# Generate once with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
# List every hostname the backend may be reached at (comma-separated). The
# bare IP is kept so we can hit the server during DNS outages or before a
# certificate is provisioned.
ALLOWED_HOSTS=103.174.102.124,api.helio.ae,localhost
# Browser origins allowed to call the API. List both http and https for the
# domain so the switch to TLS doesn't need a redeploy.
CORS_ALLOWED_ORIGINS=http://103.174.102.124,http://api.helio.ae,https://api.helio.ae
FRONTEND_URL=https://api.helio.ae/heliogram
APP_NAME=HelioGram
DEFAULT_LOCALE=en

# CSRF: comma-separated list of full origins (scheme + host[:port]) that are
# allowed to POST to Django (notably the admin login form). If left unset,
# Django auto-derives a sane default from CORS_ALLOWED_ORIGINS + ALLOWED_HOSTS.
CSRF_TRUSTED_ORIGINS=http://103.174.102.124,http://api.helio.ae,https://api.helio.ae

# Cookie security flags. TRUE is correct once HTTPS is in front (the
# default for this stack — see DEPLOY.md §6b.3 Path B). Flip both to
# False *temporarily* if you need to debug over plain HTTP on the bare IP.
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Seed superuser. The entrypoint only creates the user if it does not exist
# yet, so changing the password here after first boot has no effect (manage
# passwords via `python manage.py changepassword` inside the container).
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=

# JWT lifetimes (minutes).
JWT_ACCESS_TOKEN_LIFETIME=30
JWT_REFRESH_TOKEN_LIFETIME=10080

# Uploads.
MAX_UPLOAD_SIZE=52428800

# Email (optional; default is console backend which just logs to stdout).
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ---------------------------------------------------------------------------
# Postgres (USE_SQLITE is hard-coded to False in docker-compose.prod.yml).
# ---------------------------------------------------------------------------
DB_NAME=heliogram
DB_USER=heliogram
DB_PASSWORD=change-me-strong-password
DB_CONN_MAX_AGE=60

# ---------------------------------------------------------------------------
# Agent backends (FastAPI microservices behind /api/image, /api/video, ...).
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=
REPLICATE_API_TOKEN=
REPLICATE_IMAGE_MODEL=bytedance/seedream-4.5
REPLICATE_VIDEO_MODEL=kwaivgi/kling-v2.5-turbo-pro
IMAGE_PROMPT_LLM_MODEL=openai/gpt-4o
VIDEO_PROMPT_LLM_MODEL=openai/gpt-4o
STORYTELLER_LLM_MODEL=openai/gpt-4o
STORYTELLER_FALLBACK_MODELS=
CAMPAIGN_MAKER_LLM_MODEL=openai/gpt-4o
CAMPAIGN_MAKER_FALLBACK_MODELS=
SOUL_PRINT_LLM_MODEL=openai/gpt-4o
SOUL_PRINT_FALLBACK_MODELS=

# ---------------------------------------------------------------------------
# External / public API surface (/v1/*) — consumed by third-party sites
# (Framer landing pages, partner portals, etc.). Empty values disable the
# external surface for that agent (the routes return 503).
#
# Format for HELIO_EXTERNAL_API_KEYS_*: comma-separated entries. Each entry
# is either a bare secret or `label:secret`. The label is only used in
# logs; the secret is what authenticates. Generate one with:
#   python -c "import secrets; print('helio_live_' + secrets.token_urlsafe(32))"
# ---------------------------------------------------------------------------
HELIO_EXTERNAL_API_KEYS_IMAGE=
HELIO_EXTERNAL_API_KEYS_VIDEO=
HELIO_EXTERNAL_API_KEYS_STORYTELLER=
HELIO_EXTERNAL_API_KEYS_CAMPAIGN=
HELIO_EXTERNAL_API_KEYS_SOUL_PRINT=

# Browser origins allowed to hit /v1/* (Framer preview + production sites,
# any partner web app, etc.). Server-to-server callers ignore CORS, so an
# empty list still allows curl / backend integrations.
HELIO_EXTERNAL_ALLOWED_ORIGINS=

# Regex matching wildcard origins. ``platform.helio.ae`` is the Framer
# customer-facing domain; per-brand subdomains (e.g.
# ``binghatti.platform.helio.ae``) need to call ``api.helio.ae/v1/*``
# from the browser, so we allow any single-label subdomain of that host.
# IMPORTANT: keep this NARROW — ``*.helio.ae`` would also match
# ``api.helio.ae`` and create a self-CORS loop, plus any future helio.ae
# subdomain would inherit external API access by accident.
HELIO_EXTERNAL_ALLOWED_ORIGIN_REGEX=^https://([a-z0-9-]+\.)?platform\.helio\.ae$

# Per-key token bucket. 30 r/m + burst 10 is a sane default for image,
# storyteller, campaign-maker. The video agent overrides these defaults
# internally to 10 r/m + burst 4 because video renders are expensive.
HELIO_EXTERNAL_RATE_PER_MINUTE=30
HELIO_EXTERNAL_RATE_BURST=10

# ---------------------------------------------------------------------------
# Supabase — multi-tenant control plane.
#
# tenant-api validates Supabase-issued JWTs (against SUPABASE_JWKS_URL) and
# uses SUPABASE_SERVICE_ROLE_KEY to bypass RLS for control-plane writes
# (creating brands, issuing API keys, recording subdomains). The service
# role key is the most sensitive secret in the platform — it must NEVER
# be exposed to agents, frontends, or the browser bundle.
#
# Find these values in the Supabase dashboard:
#   Project Settings -> API
# JWKS URL is `${SUPABASE_URL}/auth/v1/.well-known/jwks.json`.
# ---------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWKS_URL=

# Browser origins allowed to call /api/tenant/* (admin UI + customer
# frontends). Exact-match list — primarily ``https://admin.helio.ae``
# for the internal admin SPA. Customer-facing brand sites use the
# wildcard regex below for *.platform.helio.ae.
TENANT_API_ALLOWED_ORIGINS=https://admin.helio.ae
TENANT_API_ALLOWED_ORIGIN_REGEX=^https://([a-z0-9-]+\.)?platform\.helio\.ae$

# ---------------------------------------------------------------------------
# Frontend (main-app) — Phase 5.8 stripped to a tiny questionnaire shell.
# Marketing pages moved to Framer; agent test surfaces moved to admin app.
# Only env still consumed by the static bundle:
# ---------------------------------------------------------------------------
VITE_COMMUNITY_URL=

# ---------------------------------------------------------------------------
# Admin SPA — baked into apps/admin at build time. Reads SUPABASE_URL +
# SUPABASE_ANON_KEY (set above) and ADMIN_API_BASE_URL below.
# ---------------------------------------------------------------------------
ADMIN_API_BASE_URL=https://api.helio.ae
