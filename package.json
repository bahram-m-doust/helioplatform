{
  "name": "helio-platform-api",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Helio Platform — pure API backend (4 Python AI agents + tenant control plane). The customer-facing site lives on Framer (platform.helio.ae); the internal admin SPA lives in apps/admin (admin.helio.ae).",
  "scripts": {
    "dev:site": "vite --config apps/main-app/frontend/vite.config.ts --port=4000 --host=0.0.0.0",
    "build": "vite build --config apps/main-app/frontend/vite.config.ts",
    "preview": "vite preview --config apps/main-app/frontend/vite.config.ts --port 4173",
    "lint": "tsc --project apps/main-app/frontend/tsconfig.json --noEmit",
    "agents:up": "node infra/scripts/agents-up.mjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.1",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
