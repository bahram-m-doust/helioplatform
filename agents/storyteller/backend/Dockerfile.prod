# syntax=docker/dockerfile:1.6
# Production image for the storyteller FastAPI microservice.
# Build context: REPO ROOT (so packages/agent-common can be COPY'd in).
FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

COPY packages/agent-common /opt/agent-common
RUN pip install --no-cache-dir -e /opt/agent-common

COPY agents/storyteller/backend/requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt
COPY agents/storyteller/backend ./

EXPOSE 8040

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8040", "--workers", "1", "--proxy-headers", "--forwarded-allow-ips", "*"]
