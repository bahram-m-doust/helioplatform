# BuildKit per-Dockerfile dockerignore (filename: <Dockerfile>.dockerignore).
# Applied on top of the root .dockerignore for THIS build only.
#
# Build context is the repo root. We pull in only what this agent needs:
#   - packages/agent-common/        (shared library)
#   - agents/image-generator/backend/  (this agent)
# Everything else gets dropped to keep the upload tight.

apps/
infra/
scripts/
docs/
services/
node_modules/
package-lock.json
agents/video-generator/
agents/storyteller/
agents/campaign-maker/
