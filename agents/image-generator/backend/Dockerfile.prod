# syntax=docker/dockerfile:1.6
# Production image for the image-generator FastAPI microservice.
# Build context: REPO ROOT (so the shared `packages/agent-common` library
# can be COPY'd in alongside the agent code).
FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# Shared library: installed once, in editable mode so a hot rebuild that
# only touches packages/agent-common doesn't have to reinstall everything.
COPY packages/agent-common /opt/agent-common
RUN pip install --no-cache-dir -e /opt/agent-common

# Agent-specific deps + source.
COPY agents/image-generator/backend/requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt
COPY agents/image-generator/backend ./

EXPOSE 8020

# Single worker keeps external API quota usage predictable; scale via
# horizontal replicas rather than more uvicorn workers per pod.
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8020", "--workers", "1", "--proxy-headers", "--forwarded-allow-ips", "*"]
