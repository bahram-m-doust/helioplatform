SECRET_KEY=replace-with-long-random-secret
DEBUG=False
ALLOWED_HOSTS=community.example.com,api.example.com,localhost,127.0.0.1
FRONTEND_URL=https://community.example.com
APP_NAME=HelioGram
DEFAULT_LOCALE=en

USE_SQLITE=False
DB_ENGINE=django.db.backends.postgresql
DB_NAME=heliogram
DB_USER=heliogram
DB_PASSWORD=replace-db-password
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONN_MAX_AGE=60

JWT_ACCESS_TOKEN_LIFETIME=30
JWT_REFRESH_TOKEN_LIFETIME=10080

STORAGE_ROOT=/opt/helio-platform/apps/heliogram/backend/storage
MAX_UPLOAD_SIZE=52428800

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=mailer@example.com
EMAIL_HOST_PASSWORD=replace-mail-password

OPENROUTER_API_KEY=replace-openrouter-key
OPENROUTER_MODEL=openai/gpt-4o
VIDEO_PROMPT_LLM_MODEL=openai/gpt-4o
IMAGE_PROMPT_LLM_MODEL=openai/gpt-4o

REPLICATE_API_TOKEN=replace-replicate-token
REPLICATE_IMAGE_MODEL=bytedance/seedream-4.5
REPLICATE_VIDEO_MODEL=kwaivgi/kling-v2.5-turbo-pro
